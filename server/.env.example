# Server
PORT=3001
NODE_ENV=development

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...   # Required — OCR (Claude Vision) + recipe structuring + ingredient substitution
OPENAI_API_KEY=sk-...           # Optional — Whisper audio transcription (falls back to captions only)

# Nutrition database
USDA_API_KEY=DEMO_KEY           # Optional — USDA FoodData Central (free key at api.data.gov; DEMO_KEY = 30 req/hr)

# Video downloading
YTDLP_PATH=yt-dlp               # Path to yt-dlp binary (defaults to 'yt-dlp' on PATH)
TEMP_DIR=/tmp/recipesnap        # Temp directory for video downloads (defaults to OS temp)

# Concurrency
MAX_CONCURRENT_JOBS=2           # Max simultaneous extraction jobs

# CORS
CORS_ORIGIN=*                   # Restrict to your frontend domain in production

# Database
DB_PATH=./data/recipesnap.db    # SQLite file path (use a volume mount in Docker)
